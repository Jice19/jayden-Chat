generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = "postgresql://jayden:123456@localhost:5432/doubao_db?schema=public"
}

model User {
  id           String    @id @default(cuid())
  username     String    @unique
  passwordHash String
  createdAt    DateTime  @default(now())
  sessions     Session[]
}

model Session {
  id        String   @id @default(cuid())
  title     String
  createdAt DateTime @default(now())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  chats     Chat[]
}

model Chat {
  id        String   @id @default(cuid())
  content   String
  isUser    Boolean
  createdAt DateTime @default(now())
  sessionId String?
  session   Session? @relation(fields: [sessionId], references: [id])
}

model GeneratedImage {
  id             String   @id @default(cuid())
  prompt         String
  url            String
  size           String
  negativePrompt String?
  createdAt      DateTime @default(now())
}

model RagDocument {
  id           String   @id
  userId       String   @map("user_id")
  originalName String   @map("original_name")
  storedName   String   @map("stored_name")
  fileHash     String   @map("file_hash")
  size         BigInt
  ext          String
  uploadedAt   DateTime @default(now()) @map("uploaded_at")
  indexStatus  String   @default("PENDING") @map("index_status")
  indexedAt    DateTime? @map("indexed_at")
  indexError   String   @default("") @map("index_error")

  @@index([userId, uploadedAt(sort: Desc)])
  @@unique([userId, fileHash, size])
  @@map("rag_documents")
}
